{
  "framework": null,
  "buildCommand": "cross-env INPUT=mcp-app.html vite build",
  "outputDirectory": "dist",
  "functions": {
    "api/mcp.ts": {
      "includeFiles": "dist/**"
    }
  },
  "rewrites": [
    { "source": "/.well-known/oauth-authorization-server", "destination": "/api/oauth/metadata" },
    { "source": "/api/oauth/register", "destination": "/api/oauth/register" },
    { "source": "/api/oauth/authorize", "destination": "/api/oauth/authorize" },
    { "source": "/api/oauth/token", "destination": "/api/oauth/token" },
    { "source": "/.well-known/oauth-protected-resource", "destination": "/api/protected-resource" },
    { "source": "/mcp", "destination": "/api/mcp" },
    { "source": "/test", "destination": "/api/test" }
  ]
}
